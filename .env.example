# Корпоративный адрес Яндекс Почты, куда приходят расшифровки.
YANDEX_EMAIL=meetings@your-company.fi

# Отдельный пароль приложения для доступа по IMAP.
# Не используйте здесь основной пароль от аккаунта.
YANDEX_APP_PASSWORD=PASTE_YANDEX_MAIL_APP_PASSWORD_HERE

# Ваш существующий OAuth-токен Яндекс Диска.
YANDEX_DISK_TOKEN=PASTE_YANDEX_DISK_OAUTH_TOKEN_HERE

# Корневая папка. В ней сервис автоматически создаст папки из config/rules.yaml.
YANDEX_DISK_ROOT=/Совещания

IMAP_HOST=imap.yandex.ru
IMAP_PORT=993
IMAP_MAILBOX=INBOX

# Частота проверки почты. Минимум, применяемый программой, — 10 секунд.
POLL_INTERVAL_SECONDS=60

# false: при первом запуске пропустить старые письма и обрабатывать только новые.
# true: при первом запуске проверить последние INITIAL_LOOKBACK_MESSAGES писем.
PROCESS_EXISTING=false
INITIAL_LOOKBACK_MESSAGES=100

TIMEZONE=Europe/Helsinki
RULES_PATH=/app/config/rules.yaml
DATABASE_PATH=/app/data/meeting_sorter.sqlite3
LOG_LEVEL=INFO
